#!/usr/bin/env bash
# sunshine-bootstrap — one-shot machine setup for the sunshine theme switcher
# idempotent: safe to re-run

set -uo pipefail

ok()   { printf '\033[32m  ✓ %s\033[0m\n' "$*"; }
warn() { printf '\033[33m  ⚠ %s\033[0m\n' "$*"; }
step() { printf '\n\033[1;36m▸ %s\033[0m\n' "$*"; }

BTOP_THEMES_DIR="$HOME/.config/btop/themes"
YAZI_FLAVORS_DIR="$HOME/.config/yazi/flavors"
ALACRITTY_THEMES_DIR="$HOME/.config/alacritty/themes"
ITERM_PRESETS_DIR="$HOME/.config/sunshine-iterm-presets"
mkdir -p "$ITERM_PRESETS_DIR"

# ── 1. Homebrew ───────────────────────────────────────────────────────────────

step "Homebrew"
command -v brew &>/dev/null \
    || /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
ok "brew"

# ── 2. Core dependencies ──────────────────────────────────────────────────────

step "Core dependencies"
for _pkg in gum figlet; do
    brew list "$_pkg" &>/dev/null || brew install "$_pkg"
    ok "$_pkg"
done

# ── 3. Apps ───────────────────────────────────────────────────────────────────

step "Apps"

_brew() {
    local pkg="$1" label="${2:-$1}"
    if brew list "$pkg" &>/dev/null; then
        ok "$label (already installed)"
    else
        brew install "$pkg" && ok "$label" || warn "$label — install failed"
    fi
}

_cask() {
    local pkg="$1" label="${2:-$1}" app="${3:-}"
    if brew list --cask "$pkg" &>/dev/null; then
        ok "$label (already installed)"
    elif [ -n "$app" ] && [ -d "/Applications/$app" ]; then
        ok "$label (already installed, not brew-managed)"
    else
        brew install --cask "$pkg" && ok "$label" || warn "$label — install failed"
    fi
}

_brew "felixkratz/formulae/borders" "borders"
_brew "btop"
_brew "neofetch"
_brew "neovim"
_brew "yazi"
_cask "ubersicht"           "Übersicht"   "Übersicht.app"
_cask "iterm2"              "iTerm2"      "iTerm.app"
_cask "visual-studio-code"  "VS Code"     "Visual Studio Code.app"
_cask "zed"                 "Zed"         "Zed.app"
_cask "alacritty"           "Alacritty"   "Alacritty.app"

# ── 4. VS Code theme extensions ───────────────────────────────────────────────

step "VS Code theme extensions"

if command -v code &>/dev/null; then
    _vscode_exts=(
        arcticicestudio.nord-visual-studio-code
        enkia.tokyo-night
        jdinhlife.gruvbox
        mvllow.rose-pine
        catppuccin.catppuccin-vsc
        qufiwefefwoyn.kanagawa
        sainnhe.everforest
    )
    for ext in "${_vscode_exts[@]}"; do
        code --install-extension "$ext" --force &>/dev/null \
            && ok "$ext" \
            || warn "$ext — install failed"
    done
else
    warn "VS Code CLI (code) not in PATH — skip extensions"
fi

# ── 5. btop themes ────────────────────────────────────────────────────────────

step "btop themes"
mkdir -p "$BTOP_THEMES_DIR"

_btop() {
    local name="$1" url="$2"
    if [ -f "$BTOP_THEMES_DIR/$name.theme" ]; then
        ok "btop/$name (already present)"
        return
    fi
    curl -fsSL "$url" -o "$BTOP_THEMES_DIR/$name.theme" \
        && ok "btop/$name" \
        || warn "btop/$name — download failed; add $name.theme to $BTOP_THEMES_DIR manually"
}

_btop "Nord" \
    "https://raw.githubusercontent.com/aristocratos/btop/main/themes/nord.theme"
_btop "tokyo-night" \
    "https://raw.githubusercontent.com/aristocratos/btop/main/themes/tokyo-night.theme"
_btop "gruvbox" \
    "https://raw.githubusercontent.com/aristocratos/btop/main/themes/gruvbox_dark_v2.theme"
_btop "rose-pine" \
    "https://raw.githubusercontent.com/rose-pine/btop/main/rose-pine.theme"
_btop "catppuccin-frappe" \
    "https://raw.githubusercontent.com/catppuccin/btop/main/themes/catppuccin_frappe.theme"
_btop "everforest" \
    "https://raw.githubusercontent.com/aristocratos/btop/main/themes/everforest-dark-hard.theme"

# kanagawa has no public btop theme — write from palette
if [ ! -f "$BTOP_THEMES_DIR/kanagawa.theme" ]; then
    cat > "$BTOP_THEMES_DIR/kanagawa.theme" <<'THEME'
