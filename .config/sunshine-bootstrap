# ── 6. yazi flavors ───────────────────────────────────────────────────────────

step "yazi flavors"
mkdir -p "$YAZI_FLAVORS_DIR"

_clone_flavor() {
    local name="$1" url="$2" subfolder="${3:-}"
    local dest="$YAZI_FLAVORS_DIR/$name.yazi"
    [ -d "$dest" ] && { ok "yazi/$name (already present)"; return; }
    if [ -n "$subfolder" ]; then
        local tmp; tmp=$(mktemp -d)
        git clone --quiet --depth=1 "$url" "$tmp" 2>/dev/null \
            && cp -r "$tmp/$subfolder" "$dest" \
            && ok "yazi/$name" \
            || warn "yazi/$name — install failed"
        rm -rf "$tmp"
    else
        git clone --quiet --depth=1 "$url" "$dest" 2>/dev/null \
            && ok "yazi/$name" \
            || warn "yazi/$name — install failed"
    fi
}

_clone_flavor "nord"              "https://github.com/AdithyanA2005/nord.yazi"
_clone_flavor "tokyo-night"       "https://github.com/BennyOe/tokyo-night.yazi"
_clone_flavor "gruvbox-dark"      "https://github.com/bennyyip/gruvbox-dark.yazi"
_clone_flavor "rose-pine"         "https://github.com/rose-pine/yazi" "flavors/rose-pine.yazi"
_clone_flavor "catppuccin-frappe" "https://github.com/yazi-rs/flavors" "catppuccin-frappe.yazi"
_clone_flavor "everforest-medium" "https://github.com/Chromium-3-Oxide/everforest-medium.yazi"
_clone_flavor "kanagawa"          "https://github.com/dangooddd/kanagawa.yazi"

# ── 7. iTerm2 color presets ───────────────────────────────────────────────────

step "iTerm2 color presets"
osascript -e 'tell application "iTerm2" to true' &>/dev/null \
    || warn "iTerm2 not running — presets may not register; re-run with iTerm2 open if needed"

_iterm_exists() {
    ITERM_CHECK_PRESET="$1" python3 <<'PYEOF' 2>/dev/null
import subprocess, plistlib, unicodedata, os, sys
name = unicodedata.normalize('NFC', os.environ['ITERM_CHECK_PRESET'])
r = subprocess.run(['defaults','export','com.googlecode.iterm2','-'], capture_output=True)
prefs = plistlib.loads(r.stdout)
presets = prefs.get('Custom Color Presets', {})
sys.exit(0 if any(unicodedata.normalize('NFC', k) == name for k in presets) else 1)
PYEOF
}

_iterm_cleanup() {
    local plist="$HOME/Library/Preferences/com.googlecode.iterm2.plist"
    local buddy=/usr/libexec/PlistBuddy
    for preset in "Nord" "Tokyo Night" "Gruvbox Dark Hard" "Kanagawa" "Everforest" "Rosé Pine"; do
        for n in 2 3 4 5; do
            "$buddy" -c "Delete 'Custom Color Presets:$preset ($n)'" "$plist" &>/dev/null \
                && ok "iTerm2 — removed '$preset ($n)'" || true
        done
    done
    "$buddy" -c "Delete 'Custom Color Presets:RosePine'" "$plist" &>/dev/null \
        && ok "iTerm2 — removed 'RosePine'" || true
    killall cfprefsd &>/dev/null || true
}

_iterm_cleanup

_iterm() {
    local preset="$1" url="$2" fname="$3"
    if _iterm_exists "$preset"; then
        ok "iTerm2/$preset (already imported)"
        return
    fi
    local fpath="$ITERM_PRESETS_DIR/$fname"
    [ -f "$fpath" ] || curl -fsSL "$url" -o "$fpath" \
        || { warn "iTerm2/$preset — download failed"; return; }
    open "$fpath" && sleep 2 \
        && ok "iTerm2/$preset" \
        || warn "iTerm2/$preset — failed; run: open '$fpath'"
}

_iterm "Nord" \
    "https://raw.githubusercontent.com/arcticicestudio/nord-iterm2/develop/src/xml/Nord.itermcolors" \
    "Nord.itermcolors"
_iterm "Tokyo Night" \
    "https://gist.githubusercontent.com/dannystewart/59a9de34206dbc67cbc468136211d048/raw/Tokyo%20Night.itermcolors" \
    "Tokyo Night.itermcolors"
_iterm "Gruvbox Dark Hard" \
    "https://raw.githubusercontent.com/mbadolato/iTerm2-Color-Schemes/master/schemes/Gruvbox%20Dark%20Hard.itermcolors" \
    "Gruvbox Dark Hard.itermcolors"
_iterm "Rosé Pine" \
    "https://raw.githubusercontent.com/rose-pine/iterm/main/rose-pine.itermcolors" \
    "Rosé Pine.itermcolors"
_iterm "Catppuccin Frappe" \
    "https://raw.githubusercontent.com/catppuccin/iterm/main/colors/catppuccin-frappe.itermcolors" \
    "Catppuccin Frappe.itermcolors"
_iterm "Kanagawa" \
    "https://raw.githubusercontent.com/rebelot/kanagawa.nvim/master/extras/iterm/kanagawa.itermcolors" \
    "Kanagawa.itermcolors"
_iterm "Everforest" \
    "https://raw.githubusercontent.com/mbadolato/iTerm2-Color-Schemes/master/schemes/Everforest%20Dark%20Hard.itermcolors" \
    "Everforest.itermcolors"

# ── 8. nvim colorscheme plugins ───────────────────────────────────────────────

step "nvim colorscheme plugins"
NVIM_THEMES="$HOME/.config/nvim/lua/plugins/themes.lua"

if [ ! -f "$NVIM_THEMES" ]; then
    cat > "$NVIM_THEMES" <<'LUA'
---@type LazySpec
return {
  { "shaunsingh/nord.nvim",     lazy = true },
  { "folke/tokyonight.nvim",    lazy = true },
  { "ellisonleao/gruvbox.nvim", lazy = true },
  { "rose-pine/neovim",         name = "rose-pine",  lazy = true },
  { "catppuccin/nvim",          name = "catppuccin", lazy = true },
  { "rebelot/kanagawa.nvim",    lazy = true },
  { "sainnhe/everforest",       lazy = true },
}
LUA
    ok "nvim/themes.lua created"
else
    ok "nvim/themes.lua (already exists)"
fi

nvim --headless -c "Lazy! sync" -c "qa" 2>/dev/null \
    && ok "nvim plugins synced" \
    || warn "nvim sync failed — open nvim and run :Lazy sync manually"

# ── 9. Alacritty themes ───────────────────────────────────────────────────────

step "Alacritty themes"
mkdir -p "$ALACRITTY_THEMES_DIR"

_alacritty_theme() {
    local name="$1"
    if [ -f "$ALACRITTY_THEMES_DIR/$name.toml" ]; then
        ok "alacritty/$name (already present)"
        return
    fi
    curl -fsSL \
        "https://raw.githubusercontent.com/alacritty/alacritty-theme/master/themes/$name.toml" \
        -o "$ALACRITTY_THEMES_DIR/$name.toml" \
        && ok "alacritty/$name" \
        || warn "alacritty/$name — download failed"
}

_alacritty_theme "nord"
_alacritty_theme "tokyo_night"
_alacritty_theme "gruvbox_dark"
_alacritty_theme "rose_pine"
_alacritty_theme "catppuccin_frappe"
_alacritty_theme "kanagawa_wave"
_alacritty_theme "everforest_dark"

# ── 10. borders seed ──────────────────────────────────────────────────────────

step "borders config"
BORDERS_COLOR_FILE="$HOME/.config/borders/active_color"
mkdir -p "$(dirname "$BORDERS_COLOR_FILE")"
if [ -f "$BORDERS_COLOR_FILE" ]; then
    ok "borders/active_color (already exists)"
else
    printf '0xff88c0d0\n' > "$BORDERS_COLOR_FILE"
    ok "borders/active_color (seeded with Nord)"
fi

# ── done ──────────────────────────────────────────────────────────────────────

printf '\n\033[1m  bootstrap complete — run ~/.config/sunshine to apply a theme\033[0m\n\n'
